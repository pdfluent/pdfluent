{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-v2-schema/main/schema.json",
  "productName": "PDFluent",
  "version": "1.0.0-beta.1",
  "identifier": "com.pdfluent.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420/?v2",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "PDFluent",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "$DOCUMENT/**", "$DESKTOP/**", "$DOWNLOAD/**", "$TEMP/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": [
      "scripts/paddle_ocr_bridge.py",
      "scripts/requirements-ocr.txt"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "Entitlements.plist",
      "signingIdentity": "-",
      "frameworks": []
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"],
        "section": "office",
        "priority": "optional"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "category": "public.app-category.productivity",
    "shortDescription": "Fast, private PDF editor",
    "longDescription": "PDFluent is a privacy-first desktop PDF editor. View, annotate, fill forms, merge, split, sign, and convert PDFs — all processed locally on your device.",
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "tsp": true,
      "signCommand": {
        "cmd": "powershell",
        "args": [
          "-NoProfile",
          "-NonInteractive",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          ".\\scripts\\sign-windows.ps1",
          "%1"
        ]
      }
    },
    "fileAssociations": [
      {
        "ext": ["pdf"],
        "mimeType": "application/pdf"
      }
    ]
  },
  "plugins": {
    "dialog": null,
    "fs": null,
    "updater": {
      "endpoints": [
        "https://github.com/pdfluent/pdfluent/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY3QzlGMjE0NTNCMjE0MDEKUldRQkZMSlRGUExKOTlFcE5BSW91eGUrM2NRY2Z2Z1Z0OTlXQWd6NUlMSmhjVVY0TCtQYmFQYW4K"
    }
  }
}
